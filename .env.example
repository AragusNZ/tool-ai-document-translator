# document-translator — environment variable template
#
# The CLI reads the process environment only; it does not load .env files automatically.
# Copy this file, fill in values, then export before running:
#
#   cp .env.example .env
#   set -a && source .env && set +a
#
# Full reference: README.md § Configuration
# Discover LLM selectors: document-translator list-llms
# Preflight check: document-translator check

# -----------------------------------------------------------------------------
# LLM provider (set the API key matching your selected provider)
# -----------------------------------------------------------------------------

# LLM selector as provider:model (alias: LLM)
# Default: cursor:composer-2.5
# DOCUMENT_TRANSLATOR_LLM=cursor:composer-2.5

# Required for live runs when LLM uses cursor:* (alias: DOCUMENT_TRANSLATOR_CURSOR_API_KEY)
# CURSOR_API_KEY=

# Required for live runs when LLM uses openai:* (alias: DOCUMENT_TRANSLATOR_OPENAI_API_KEY)
# OPENAI_API_KEY=

# Required for live runs when LLM uses anthropic:* (alias: DOCUMENT_TRANSLATOR_ANTHROPIC_API_KEY)
# ANTHROPIC_API_KEY=

# Required for live runs when LLM uses google:* (alias: DOCUMENT_TRANSLATOR_GOOGLE_API_KEY)
# GOOGLE_API_KEY=

# Deprecated — bare Cursor model name; prefer DOCUMENT_TRANSLATOR_LLM (alias: TRANSLATION_MODEL)
# DOCUMENT_TRANSLATOR_TRANSLATION_MODEL=composer-2.5

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------

# Override project root (default: repository root)
# DOCUMENT_TRANSLATOR_ROOT=

# Job output directory, relative to root unless absolute (default: runs)
# DOCUMENT_TRANSLATOR_RUNS_DIR=runs

# -----------------------------------------------------------------------------
# Pipeline tuning
# -----------------------------------------------------------------------------

# Max characters per translation chunk (default: 2500)
# DOCUMENT_TRANSLATOR_CHUNK_SIZE=2500

# Sentence overlap between adjacent chunks (default: 2)
# DOCUMENT_TRANSLATOR_CHUNK_OVERLAP_SENTENCES=2

# RapidFuzz ratio below which sentences are flagged in thorough mode (default: 92.0)
# DOCUMENT_TRANSLATOR_SIMILARITY_THRESHOLD=92.0

# Parallel translation workers per pass (default: 4)
# DOCUMENT_TRANSLATOR_MAX_CONCURRENT_CHUNKS=4

# Below this, language detection uses AI fallback (default: 0.85)
# DOCUMENT_TRANSLATOR_LANG_CONFIDENCE_THRESHOLD=0.85

# Fail the job if extraction yields no body text (default: false)
# DOCUMENT_TRANSLATOR_FAIL_ON_EMPTY_EXTRACTION=false

# Maximum job duration in seconds; cooperative timeout between stages
# Aliases: JOB_TIMEOUT, DOCUMENT_TRANSLATOR_JOB_TIMEOUT_SECONDS
# DOCUMENT_TRANSLATOR_JOB_TIMEOUT=

# HTTPS URL for terminal job webhook POST (alias: WEBHOOK_URL)
# DOCUMENT_TRANSLATOR_WEBHOOK_URL=

# HMAC secret for X-Document-Translator-Signature (alias: WEBHOOK_SECRET)
# DOCUMENT_TRANSLATOR_WEBHOOK_SECRET=

# Webhook HTTP timeout in seconds (default: 30)
# DOCUMENT_TRANSLATOR_WEBHOOK_TIMEOUT_SECONDS=30

# Retain intermediate working files after finalize — debug only (default: false)
# DOCUMENT_TRANSLATOR_KEEP_WORK_FILES=false

# -----------------------------------------------------------------------------
# PDF / OCR
# -----------------------------------------------------------------------------

# Enable per-page OCR fallback for sparse PDF pages (default: true)
# DOCUMENT_TRANSLATOR_PDF_OCR=true

# Tesseract language pack(s), e.g. eng+spa (default: eng)
# DOCUMENT_TRANSLATOR_PDF_OCR_LANGUAGES=eng

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# DEBUG, INFO, WARNING, ERROR (default: INFO)
# DOCUMENT_TRANSLATOR_LOG_LEVEL=INFO

# text or json — json emits structured logs on stderr (default: text)
# DOCUMENT_TRANSLATOR_LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Sentry (requires pip install document-translator[monitoring])
# -----------------------------------------------------------------------------

# Sentry DSN (alias: SENTRY_DSN)
# DOCUMENT_TRANSLATOR_SENTRY_DSN=

# Sentry environment tag, e.g. production
# DOCUMENT_TRANSLATOR_SENTRY_ENVIRONMENT=

# Performance trace sample rate 0.0–1.0 (default: 0.0)
# DOCUMENT_TRANSLATOR_SENTRY_TRACES_SAMPLE_RATE=0.0

# Comma-separated severities sent as Sentry events: error, warn, info (default: error)
# DOCUMENT_TRANSLATOR_SENTRY_REPORT_SEVERITIES=error
